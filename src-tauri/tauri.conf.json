{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "滴答清单",
  "version": "1.43.2",
  "identifier": "com.dida.local",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "滴答清单",
        "width": 1200,
        "height": 800,
        "minWidth": 480,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false,
        "decorations": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https:;"
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFGRDdDODg0QkQzREEyM0EKUldRNm9qMjloTWpYSDhUTmcwV2RpR1ZnQTYwejBwYkwvd3NEOVFiYTJ0RXZDaTFoRVJGR2o3NkcK",
      "endpoints": ["https://raw.githubusercontent.com/Lukeli1/dida-clone/main/latest.json"]
    }
  }
}
